# Copy this file to .env and fill in real values as you get them.
# Every AI-related key below is optional: with a key absent, that provider
# runs in mock/demo mode and the app still works end to end.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- PostgreSQL ---
POSTGRES_DB=mydoc24
POSTGRES_USER=mydoc24
POSTGRES_PASSWORD=mydoc24
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- AI providers (leave blank to run in mock/demo mode) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
DID_API_KEY=

# --- Web Push (VAPID): leave blank to disable the daily check-in reminder toggle ---
# Generate a keypair with: docker compose exec backend python manage.py generate_vapid_keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_ADMIN_EMAIL=admin@example.com

# --- Frontend ---
VITE_DEV_SERVER_PORT=5173
